{
	"schemaVersion": 1,
	"id": "create-sophisticated-storage-compatibility",
	"version": "${version}",
	"name": "Create: Sophisticated Storage Compatibility",
	"description": "A compatibility mod that enables interaction between Create's mechanical systems and Sophisticated Storage's advanced chests for automatic item transfers.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "logo.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.sypherred.sophisticated_compatibility.CreateSophisticatedStorageCompatibility"
		],
		"fabric-datagen": [
			"net.sypherred.sophisticated_compatibility.CreateSophisticatedStorageCompatibilityDataGenerator"
		]
	},
	"mixins": [
		"create-sophisticated-storage-compatibility.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"create": "*",
		"sophisticatedstorage": "*"
	}
}